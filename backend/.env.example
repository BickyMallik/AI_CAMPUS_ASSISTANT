# ─── AI Campus Assistant — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub!

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=campus_assistant

# ── AI API (OpenRouter — Free tier) ──────────────────────────────────────────
# Sign up at https://openrouter.ai (no credit card required)
# Create an API key → paste below
OPENROUTER_API_KEY=gsk_your_openrouter_api_key_here

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=admin123

# ── Server (Render will set PORT automatically) ───────────────────────────────
PORT=8000
